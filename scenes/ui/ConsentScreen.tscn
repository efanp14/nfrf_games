[node name="HSep1" type="HSeparator" parent="CenterContainer/PopupPanel/MarginContainer/VBoxContainer"]

[node name="BodyLabel" type="Label" parent="CenterContainer/PopupPanel/MarginContainer/VBoxContainer"]
text = "⚠ PLACEHOLDER TEXT — DO NOT USE FOR A REAL SESSION UNTIL REPLACED ⚠

[Purpose] This study investigates how people allocate infrastructure investment decisions, individually and as a group. [Replace with REB/IRB-approved purpose statement.]

[What's involved] You will complete a short pre-survey, play a city-planning game across several rounds (~15-20 minutes), and complete a short post-survey. [Add condition-specific detail, e.g. audio/video recording in group sessions, if applicable.]

[Voluntary participation] Your participation is completely voluntary. You may withdraw at any time without penalty by informing the researcher, and may decline to answer any question.

[Confidentiality] Your responses are recorded under a session ID, not your name. [Replace with your institution's actual data handling/storage/retention statement.]

[Contact] Questions about this study can be directed to [researcher name/email]. Questions about your rights as a participant can be directed to [REB/IRB contact]."
autowrap_mode = 3
theme_override_font_sizes/font_size = 12

[node name="HSep2" type="HSeparator" parent="CenterContainer/PopupPanel/MarginContainer/VBoxContainer"]

[node name="AckCheckBox" type="CheckBox" parent="CenterContainer/PopupPanel/MarginContainer/VBoxContainer"]
