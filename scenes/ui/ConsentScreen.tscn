[node name="HSep3" type="HSeparator" parent="CenterContainer/PopupPanel/MarginContainer/VBoxContainer"]

[node name="ButtonRow" type="HBoxContainer" parent="CenterContainer/PopupPanel/MarginContainer/VBoxContainer"]
